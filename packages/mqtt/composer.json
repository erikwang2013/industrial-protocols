{
    "name": "erikwang2013/industrial-protocols-mqtt",
    "type": "industrial-protocol",
    "require": {
        "php": ">=8.1",
        "erikwang2013/industrial-protocols-kernel": "*"
    },
    "autoload": {
        "psr-4": {
            "Erikwang2013\\IndustrialProtocols\\Mqtt\\": "src/"
        }
    },
